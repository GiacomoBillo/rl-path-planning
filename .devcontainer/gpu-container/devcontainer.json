{
  "name": "Avoid Everything (GPU)",

  // GPU version of the dev container   
  "dockerComposeFile": ["../docker-compose.yaml"],
  "service": "avoid-everything-dev",
  "workspaceFolder": "/workspace",
  
  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-python.black-formatter",
        "ms-toolsai.jupyter",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "python.analysis.extraPaths": [
          "/opt/ros/humble/lib/python3.10/site-packages",
          "/opt/ros/humble/local/lib/python3.10/dist-packages",
          "/workspace/avoid_everything",
          "/workspace/viz_server/src",
          "/workspace/robofin"
        ],
        "python.linting.pylintArgs": [
          "--init-hook=import sys; sys.path.append('/opt/ros/humble/lib/python3.10/site-packages'); sys.path.append('/opt/ros/humble/local/lib/python3.10/dist-packages'); sys.path.append('/workspace/avoid_everything')"
        ],
        "pylint.args": [
          "--init-hook=import sys; sys.path.append('/opt/ros/humble/lib/python3.10/site-packages'); sys.path.append('/opt/ros/humble/local/lib/python3.10/dist-packages'); sys.path.append('/workspace/avoid_everything')"
        ]
      }
    }
  },
  
  // Add features to the dev container
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "installOhMyZsh": false,
      "upgradePackages": false
    }
  },
  
  // Set environment variables
  "remoteEnv": {
    "PYTHONPATH": "/workspace:/workspace/robofin:/workspace/avoid_everything:/opt/ros/humble/lib/python3.10/site-packages:/opt/ros/humble/local/lib/python3.10/dist-packages:${PYTHONPATH}",
    "DISPLAY": "${localEnv:DISPLAY}",
    "ROS_DOMAIN_ID": "0"
  },
  
    // Set git safe directory, initialize submodules, apply patches to submodules and install robofin
  "postCreateCommand": "git config --global --add safe.directory /workspace && git config --global --add safe.directory /workspace/robofin && git -C /workspace submodule update --init --recursive && git -C /workspace/robofin apply --check /workspace/.devcontainer/patches/robofin-fixes.patch 2>/dev/null && git -C /workspace/robofin apply /workspace/.devcontainer/patches/robofin-fixes.patch; pip install -e /workspace/robofin && pip install -e /workspace/viz_server",

  // Keep container running
  "shutdownAction": "stopCompose"
} 